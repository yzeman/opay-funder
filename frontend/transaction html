    // Filter transactions by month/year, category, and status
    function getFilteredTransactions() {
        let transactions = getTransactions();
        
        // Filter by month and year
        const monthMap = {
            'January': 0, 'February': 1, 'March': 2, 'April': 3, 'May': 4, 'June': 5,
            'July': 6, 'August': 7, 'September': 8, 'October': 9, 'November': 10, 'December': 11
        };
        const selectedMonthIndex = monthMap[currentMonth];
        
        transactions = transactions.filter(tx => {
            return tx.dateObj.getMonth() === selectedMonthIndex && 
                   tx.dateObj.getFullYear() === currentYear;
        });
        
        // Filter by category
        if (currentCategory !== 'All Categories') {
            transactions = transactions.filter(tx => tx.category === currentCategory);
        }
        
        // Filter by status
        if (currentStatus !== 'All Status') {
            const statusMap = {
                'Successful': 'success',
                'Pending': 'pending',
                'Failed': 'failed',
                'To be paid': 'pending',
                'Reversed': 'failed'
            };
            const mappedStatus = statusMap[currentStatus];
            if (mappedStatus) {
                transactions = transactions.filter(tx => tx.status === mappedStatus);
            }
        }
        
        return transactions;
    }

    function calculateTotals(transactions) {
        let totalIn = 0, totalOut = 0;
        transactions.forEach(tx => {
            if (tx.type === 'credit') totalIn += tx.amount;
            else totalOut += tx.amount;
        });
        return { totalIn, totalOut };
    }

    function getTransactionIcon(category) {
        const icons = {
            'OWealth': '<i class="fas fa-chart-line"></i>',
            'Airtime': '<i class="fas fa-signal"></i>',
            'Mobile Data': '<i class="fas fa-wifi"></i>',
            'Transfer to': '<i class="fas fa-paper-plane"></i>',
            'Transfer from': '<i class="fas fa-download"></i>',
            'Add Money': '<i class="fas fa-plus-circle"></i>',
            'Betting': '<i class="fas fa-futbol"></i>'
        };
        return icons[category] || '<i class="fas fa-exchange-alt"></i>';
    }

    function formatAmount(amount, type) {
        const formatted = '₦' + amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        return type === 'credit' ? `+${formatted}` : `-${formatted}`;
    }

    // Navigate to receipt page with transaction data
    function showReceipt(tx) {
        const encodedData = encodeURIComponent(JSON.stringify(tx));
        window.location.href = `receipt.html?data=${encodedData}`;
    }

    function renderTransactions() {
        const container = document.getElementById('transactionsContent');
        const filteredTransactions = getFilteredTransactions();
        const { totalIn, totalOut } = calculateTotals(filteredTransactions);
        
        container.innerHTML = `
            <div class="month-section">
                <div class="month-header-row">
                    <div class="month-title" id="monthSelector">
                        ${currentMonth} <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="analysis-text">Analysis</div>
                </div>
                <div class="summary-row">
                    <div class="summary-item">
                        <span class="summary-label">In</span>
                        <span class="summary-amount">₦${totalIn.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">Out</span>
                        <span class="summary-amount">₦${totalOut.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>
                    </div>
                </div>
            </div>
            
            <div class="transaction-list">
                ${filteredTransactions.length === 0 ? 
                    `<div class="empty-state"><i class="fas fa-inbox"></i><div>No transactions found</div></div>` :
                    filteredTransactions.map((tx, index) => `
                        <div class="transaction-item" data-index="${index}">
                            <div class="transaction-icon">
                                ${getTransactionIcon(tx.category)}
                            </div>
                            <div class="transaction-details">
                                <div class="transaction-title">${tx.title}</div>
                                <div class="transaction-date">${tx.date}</div>
                            </div>
                            <div class="transaction-amount">
                                <div class="amount-value">${formatAmount(tx.amount, tx.type)}</div>
                                <div class="transaction-status status-${tx.status}">
                                    ${tx.status === 'success' ? 'Successful' : tx.status === 'pending' ? 'Pending' : 'Failed'}
                                </div>
                            </div>
                        </div>
                    `).join('')
                }
            </div>
        `;
        
        // Add click handlers for each transaction
        document.querySelectorAll('.transaction-item').forEach((item, idx) => {
            item.addEventListener('click', () => {
                const tx = filteredTransactions[idx];
                if (tx) showReceipt(tx);
            });
        });
        
        document.getElementById('monthSelector')?.addEventListener('click', () => showSheet(monthSheet));
    }

    // Sheet functions
    const categorySheet = document.getElementById('categorySheet');
    const statusSheet = document.getElementById('statusSheet');
    const monthSheet = document.getElementById('monthSheet');
    
    function showSheet(sheet) { if (sheet) { sheet.style.display = 'flex'; document.body.style.overflow = 'hidden'; } }
    function hideSheet(sheet) { if (sheet) { sheet.style.display = 'none'; document.body.style.overflow = ''; } }

    // Category handlers
    document.getElementById('categoryFilterBtn')?.addEventListener('click', () => showSheet(categorySheet));
    categorySheet?.addEventListener('click', (e) => { if (e.target === categorySheet || e.target.classList.contains('sheet-overlay')) hideSheet(categorySheet); });
    document.querySelectorAll('.category-item').forEach(item => {
        item.addEventListener('click', () => {
            currentCategory = item.getAttribute('data-category');
            document.getElementById('selectedCategory').textContent = currentCategory;
            document.querySelectorAll('.category-item').forEach(i => i.classList.remove('selected'));
            item.classList.add('selected');
            hideSheet(categorySheet);
            renderTransactions();
        });
    });

    // Status handlers
    document.getElementById('statusFilterBtn')?.addEventListener('click', () => showSheet(statusSheet));
    statusSheet?.addEventListener('click', (e) => { if (e.target === statusSheet || e.target.classList.contains('sheet-overlay')) hideSheet(statusSheet); });
    document.querySelectorAll('.status-item').forEach(item => {
        item.addEventListener('click', () => {
            currentStatus = item.getAttribute('data-status');
            document.getElementById('selectedStatus').textContent = currentStatus;
            document.querySelectorAll('.status-item').forEach(i => i.classList.remove('selected'));
            item.classList.add('selected');
            hideSheet(statusSheet);
            renderTransactions();
        });
    });

    // Close buttons for sheets
    document.querySelectorAll('.close-sheet-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            hideSheet(categorySheet);
            hideSheet(statusSheet);
            hideSheet(monthSheet);
        });
    });

    // Month selector
    function generateYears() {
        const yearList = document.getElementById('yearList');
        let yearsHtml = '';
        for (let year = 2020; year <= 2028; year++) {
            yearsHtml += `<div class="year-item ${year === currentYear ? 'selected' : ''}" data-year="${year}">${year}</div>`;
        }
        yearList.innerHTML = yearsHtml;
        document.querySelectorAll('.year-item').forEach(item => {
            item.addEventListener('click', () => {
                document.querySelectorAll('.year-item').forEach(i => i.classList.remove('selected'));
                item.classList.add('selected');
                currentYear = parseInt(item.getAttribute('data-year'));
                document.getElementById('selectedYearDisplay').textContent = currentYear;
            });
        });
    }

    function setupMonthGrid() {
        document.querySelectorAll('.month-grid-item').forEach(item => {
            item.addEventListener('click', () => {
                document.querySelectorAll('.month-grid-item').forEach(i => i.classList.remove('selected'));
                item.classList.add('selected');
                currentMonth = item.getAttribute('data-month');
                document.getElementById('selectedMonthDisplay').textContent = currentMonth;
            });
        });
    }

    document.getElementById('confirmMonthBtn')?.addEventListener('click', () => {
        hideSheet(monthSheet);
        renderTransactions();
    });

    generateYears();
    setupMonthGrid();

    // Download button
    document.getElementById('downloadBtn')?.addEventListener('click', () => {
        Swal.fire({ icon: 'info', title: 'Coming Soon', text: 'Download feature will be available soon', confirmButtonColor: '#00B875' });
    });

    // Initialize
    loadUserFromLocalStorage();
    renderTransactions();
    
    console.log('✅ Transaction page loaded - clicking transaction opens receipt.html');
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
    <title>OPay - Transactions</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: #f8f9fc;
            padding-bottom: 30px;
        }

        /* Header */
        .header {
            background: white;
            padding: 16px 16px 0px;
            border-bottom: 1px solid #eee;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 15px;
        }

        .back-btn {
            background: none;
            border: none;
            font-size: 20px;
            cursor: pointer;
            color: #333;
            padding: 5px;
            width: 40px;
        }

        .header-title {
            font-size: 15px;
            font-weight: 600;
            color: #1a1a1a;
            margin: 0;
            flex: 1;
            text-align: center;
        }

        .download-btn {
            background: none;
            border: none;
            font-size: 18px;
            cursor: pointer;
            color: #333;
            padding: 5px;
            width: 40px;
            transition: all 0.2s;
        }

        .download-btn:active {
            transform: scale(0.95);
            color: #00B875;
        }

        /* Filter Bar */
        .filter-bar {
            display: flex;
            gap: 12px;
            padding: 12px 16px;
            background: white;
        }

        .filter-item {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 16px;
            background: #f8f9fa;
            border-radius: 25px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 400;
            color: #1a1a1a;
            transition: all 0.2s;
        }

        .filter-item:active {
            transform: scale(0.98);
            background: #e8eaed;
        }

        .filter-item i {
            font-size: 12px;
            color: #00B875;
        }

        /* Month Section */
        .month-section {
            background: white;
            margin: 16px;
            border-radius: 20px;
            padding: 16px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .month-header-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .month-title {
            font-size: 16px;
            font-weight: 600;
            color: #1a1a1a;
            cursor: pointer;
            display: flex;
            align-items: center;
        }

        .month-title i {
            font-size: 12px;
            margin-left: 6px;
            color: #999;
        }

        .analysis-text {
            font-size: 13px;
            color: #888;
            font-weight: 400;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .summary-item {
            display: flex;
            align-items: baseline;
            gap: 8px;
        }

        .summary-label {
            font-size: 13px;
            color: #555;
        }

        .summary-amount {
            font-size: 16px;
            font-weight: 600;
            color: #1a1a1a;
        }

        /* Smaller Transaction Icons */
        .transaction-icon {
            width: 36px;
            height: 36px;
            background: #f0fdf4;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
        }

        .transaction-icon i {
            font-size: 16px;
            color: #00B875;
        }

        /* Transaction Amount - BLACK color */
        .amount-value {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 4px;
            color: #1a1a1a;
        }

        .transaction-status {
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 12px;
            display: inline-block;
        }

        .status-success {
            background: #e8f5e9;
            color: #00B875;
        }

        .status-pending {
            background: #fff3cd;
            color: #ffc107;
        }

        .status-failed {
            background: #ffebee;
            color: #dc3545;
        }

        /* Bottom Sheet Styles */
        .bottom-sheet {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 2000;
            display: flex;
            align-items: flex-end;
        }

        .sheet-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
        }

        .sheet-content {
            position: relative;
            background: white;
            width: 100%;
            border-radius: 28px 28px 0 0;
            max-height: 70vh;
            overflow-y: auto;
            animation: slideUp 0.3s ease;
        }

        @keyframes slideUp {
            from { transform: translateY(100%); }
            to { transform: translateY(0); }
        }

        .sheet-header {
            text-align: center;
            padding: 16px 20px;
            border-bottom: 1px solid #f0f0f0;
            position: sticky;
            top: 0;
            background: white;
        }

        .sheet-handle {
            width: 40px;
            height: 4px;
            background: #ddd;
            border-radius: 2px;
            margin: 0 auto 12px;
        }

        .sheet-title {
            font-size: 18px;
            font-weight: 600;
            color: #1a1a1a;
        }

        .sheet-body {
            padding: 12px 0;
        }

        .category-item, .status-item {
            padding: 14px 20px;
            font-size: 15px;
            color: #1a1a1a;
            cursor: pointer;
            transition: all 0.2s;
            border-bottom: 1px solid #f5f5f5;
        }

        .category-item.selected, .status-item.selected {
            background: #f0fdf4;
            color: #00B875;
            font-weight: 500;
        }

        .selector-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 20px;
            border-bottom: 1px solid #f0f0f0;
        }

        .selector-label {
            font-size: 14px;
            color: #888;
        }

        .selector-value {
            font-size: 14px;
            font-weight: 600;
            color: #1a1a1a;
        }

        .month-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            padding: 16px 20px;
        }

        .month-grid-item {
            text-align: center;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 25px;
            font-size: 13px;
            cursor: pointer;
        }

        .month-grid-item.selected {
            background: #00B875;
            color: white;
        }

        .year-list {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            padding: 16px 20px;
        }

        .year-item {
            text-align: center;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 25px;
            font-size: 13px;
            cursor: pointer;
        }

        .year-item.selected {
            background: #00B875;
            color: white;
        }

        .confirm-month-btn {
            width: 100%;
            padding: 14px;
            background: #00B875;
            color: white;
            border: none;
            border-radius: 30px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
        }

        .sheet-footer {
            padding: 16px 20px 30px;
            border-top: 1px solid #f0f0f0;
        }

        .close-sheet-btn {
            width: 100%;
            padding: 14px;
            background: #f0f2f5;
            border: none;
            border-radius: 30px;
            font-size: 15px;
            font-weight: 600;
            color: #666;
            cursor: pointer;
        }

        /* Transaction List */
        .transaction-list {
            background: white;
            margin: 0 16px 16px;
            border-radius: 20px;
            overflow: hidden;
        }

        .transaction-item {
            display: flex;
            align-items: center;
            padding: 14px 16px;
            border-bottom: 1px solid #f0f0f0;
            cursor: pointer;
            transition: all 0.2s;
        }

        .transaction-item:active {
            background: #f8f9fc;
        }

        .transaction-item:last-child {
            border-bottom: none;
        }

        .transaction-details {
            flex: 1;
        }

        .transaction-title {
            font-size: 14px;
            font-weight: 600;
            color: #1a1a1a;
            margin-bottom: 4px;
        }

        .transaction-date {
            font-size: 11px;
            color: #999;
        }

        .transaction-amount {
            text-align: right;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #888;
        }

        .loading {
            text-align: center;
            padding: 50px;
            color: #888;
        }

        /* Receipt Modal */
        .receipt-modal .swal2-popup {
            padding: 20px;
            border-radius: 28px;
            max-width: 380px;
        }
        
        .receipt-content {
            text-align: left;
        }
        
        .receipt-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid #eee;
        }
        
        .receipt-label {
            color: #888;
            font-size: 13px;
        }
        
        .receipt-value {
            font-weight: 600;
            color: #1a1a1a;
            font-size: 13px;
            text-align: right;
            max-width: 60%;
            word-break: break-word;
        }
        
        .receipt-status {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
        }
        
        .receipt-status.success {
            background: #e8f5e9;
            color: #00B875;
        }
        
        .receipt-status.pending {
            background: #fff3cd;
            color: #ffc107;
        }
        
        .receipt-status.failed {
            background: #ffebee;
            color: #dc3545;
        }
        
        .receipt-section {
            margin-bottom: 20px;
        }
        
        .receipt-section-title {
            font-weight: 600;
            margin-bottom: 12px;
            color: #1a1a1a;
            font-size: 15px;
        }
        
        .receipt-timeline {
            background: #f8f9fa;
            border-radius: 16px;
            padding: 16px;
            margin-bottom: 20px;
        }
        
        .timeline-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
        }
        
        .timeline-item:last-child {
            margin-bottom: 0;
        }
        
        .timeline-label {
            font-size: 12px;
            color: #888;
        }
        
        .timeline-value {
            font-size: 12px;
            font-weight: 500;
        }
        
        .action-buttons {
            display: flex;
            gap: 12px;
        }
        
        .action-btn {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 30px;
            font-weight: 500;
            font-size: 13px;
            cursor: pointer;
        }
        
        .action-btn.primary {
            background: #f0fdf4;
            color: #00B875;
        }
        
        .action-btn.secondary {
            background: #f0f2f5;
            color: #666;
        }
        
        .footer-actions {
            display: flex;
            gap: 16px;
            justify-content: center;
            padding-top: 16px;
            border-top: 1px solid #eee;
        }
        
        .footer-action-btn {
            background: none;
            border: none;
            font-size: 13px;
            cursor: pointer;
        }
        
        .footer-action-btn.report {
            color: #dc3545;
        }
        
        .footer-action-btn.share {
            color: #00B875;
        }
    </style>
</head>
